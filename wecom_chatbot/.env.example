# ==============================================================
# ZCAMP 企业微信 AI 客服 — 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ==============================================================

# ---- 企业微信配置（必填）----
WECOM_CORP_ID=your_corp_id_here
WECOM_APP_SECRET=your_app_secret_here
WECOM_AGENT_ID=your_agent_id_here
WECOM_TOKEN=your_callback_token_here
WECOM_ENCODING_AES_KEY=your_encoding_aes_key_here

# ---- AI 大模型配置（必填）----
OPENAI_API_KEY=your_openai_api_key_here

# 可选：使用国产大模型时替换为对应的 API 地址
# 例如 DeepSeek: https://api.deepseek.com/v1
# 例如 智谱 AI: https://open.bigmodel.cn/api/paas/v4
# OPENAI_BASE_URL=https://api.openai.com/v1

# 可选：指定模型名称
# OPENAI_MODEL=gpt-4o

# ---- 服务配置（可选）----
# SERVER_PORT=8080
# LOG_LEVEL=INFO

# ---- 对话管理（可选）----
# MAX_HISTORY_TURNS=20
# HISTORY_TTL_SECONDS=1800
